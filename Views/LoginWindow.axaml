<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnturnedModLoader.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="480" d:DesignHeight="520"
        x:Class="UnturnedModLoader.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="登录 - Unturned Mod Loader"
        Width="480" Height="520"
        MinWidth="420" MinHeight="480"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgCanvasBrush}">

    <Border Margin="24"
            Background="{StaticResource BgPaperBrush}"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="32,28">
        <Grid RowDefinitions="Auto,*,Auto">

            <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,24" HorizontalAlignment="Center">
                <Border Width="48" Height="48"
                        CornerRadius="12"
                        Background="{StaticResource InkBrush}"
                        HorizontalAlignment="Center">
                    <LucideIcon Kind="LogIn"
                                Size="24"
                                Foreground="{StaticResource BgPaperBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="登录账号"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="登录后可同步收藏、下载记录等个人数据"
                           FontSize="13"
                           Foreground="{StaticResource MidGrayBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="320" />
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="16" VerticalAlignment="Center">

                <Border IsVisible="{Binding HasError}"
                        Background="#FFF5F5"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,10">
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="12"
                               Foreground="{StaticResource EmberBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Spacing="8">
                    <TextBlock Text="用户名"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MidGrayBrush}" />
                    <TextBox Text="{Binding Username}"
                             PlaceholderText="请输入用户名"
                             IsEnabled="{Binding !IsBusy}" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="密码"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MidGrayBrush}" />
                    <TextBox Text="{Binding Password}"
                             PasswordChar="●"
                             PlaceholderText="请输入密码"
                             IsEnabled="{Binding !IsBusy}" />
                </StackPanel>

                <Button Classes="primary"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        HorizontalAlignment="Stretch"
                        Padding="0,10"
                        Margin="0,4,0,0">
                    <Panel>
                        <TextBlock Text="登录"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding !IsBusy}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    IsVisible="{Binding IsBusy}">
                            <LucideIcon Kind="Loader"
                                        Size="16"
                                        Classes="loader"
                                        Foreground="{StaticResource BgPaperBrush}" />
                            <TextBlock Text="{Binding BusyText}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Panel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="4"
                        Margin="0,24,0,0">
                <TextBlock Text="还没有账号？"
                           FontSize="13"
                           Foreground="{StaticResource MidGrayBrush}"
                           VerticalAlignment="Center" />
                <Button Classes="ghost"
                        Content="立即注册"
                        Command="{Binding GoToRegisterCommand}"
                        IsEnabled="{Binding !IsBusy}"
                        Padding="6,4" />
            </StackPanel>
        </Grid>
    </Border>
</Window>