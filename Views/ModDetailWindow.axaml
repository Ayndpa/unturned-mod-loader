<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnturnedModLoader.ViewModels"
        xmlns:api="using:UnturnedModLoader.Models.Api"
        xmlns:controls="using:UnturnedModLoader.Controls"
        xmlns:i18n="using:UnturnedModLoader.I18n"
        xmlns:c="https://codewf.com"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="640" d:DesignHeight="560"
        x:Class="UnturnedModLoader.Views.ModDetailWindow"
        x:DataType="vm:ModDetailViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{c:I18n {x:Static i18n:ModDetail.Title}}"
        Width="720" Height="620"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgCanvasBrush}">

    <Border Margin="20"
            Background="{StaticResource BgPaperBrush}"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24,20">
        <Grid RowDefinitions="Auto,*,Auto">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.Title}}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Classes="icon"
                        Command="{Binding CloseCommand}"
                        ToolTip.Tip="{c:I18n {x:Static i18n:Common.Close}}">
                    <LucideIcon Kind="X" Size="18" />
                </Button>
            </Grid>

            <Panel Grid.Row="1">

                <Border IsVisible="{Binding IsLoading}"
                        Background="Transparent">
                    <StackPanel Spacing="12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <LucideIcon Kind="Loader"
                                    Size="28"
                                    Classes="loader"
                                    Foreground="{StaticResource MidGrayBrush}" />
                        <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.Loading}}"
                                   FontSize="13"
                                   Foreground="{StaticResource MidGrayBrush}" />
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding HasError}"
                        Background="Transparent">
                    <StackPanel Spacing="12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="360">
                        <LucideIcon Kind="CircleAlert"
                                    Size="32"
                                    Foreground="{StaticResource EmberBrush}"
                                    HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="13"
                                   Foreground="{StaticResource MidGrayBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <ScrollViewer IsVisible="{Binding ShowContent}">
                    <StackPanel Spacing="16">

                        <Grid ColumnDefinitions="140,*" ColumnSpacing="16">
                            <controls:ModCoverPreview Grid.Column="0"
                                                      Source="{Binding CoverImage}"
                                                      HasImage="{Binding HasCoverImage}"
                                                      PreviewTitle="{Binding Title}"
                                                      ThumbnailSize="140"
                                                      HoverZoomSize="320"
                                                      PlaceholderIconSize="32" />

                            <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <LucideIcon Kind="UserRound" Size="14" Foreground="{StaticResource MidGrayBrush}" />
                                    <TextBlock FontSize="13" Foreground="{StaticResource MidGrayBrush}">
                                        <Run Text="{Binding Author}" />
                                        <Run Text=" · " />
                                        <Run Text="{Binding Version}" />
                                    </TextBlock>
                                </StackPanel>
                                <Border Background="{StaticResource BgSurfaceAltBrush}"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,3"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="12"
                                               Foreground="{StaticResource MidGrayBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="8">
                            <controls:MarkdownContentControl Markdown="{Binding DescriptionMarkdown}"
                                                             ForegroundBrush="{StaticResource InkSoftBrush}"
                                                             MutedForegroundBrush="{StaticResource MidGrayBrush}"
                                                             IsVisible="{Binding HasDescription}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Common.NoDescription}}"
                                       FontSize="13"
                                       Foreground="{StaticResource MidGrayBrush}"
                                       FontStyle="Italic"
                                       IsVisible="{Binding !HasDescription}" />
                        </StackPanel>

                        <Border Background="{StaticResource BgSurfaceAltBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,12">
                            <Grid ColumnDefinitions="*,*,*,*">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.Downloads}}"
                                               FontSize="11"
                                               Foreground="{StaticResource MidGrayBrush}" />
                                    <TextBlock Text="{Binding DownloadsText}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.Likes}}"
                                               FontSize="11"
                                               Foreground="{StaticResource MidGrayBrush}" />
                                    <TextBlock Text="{Binding LikesText}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.Comments}}"
                                               FontSize="11"
                                               Foreground="{StaticResource MidGrayBrush}" />
                                    <TextBlock Text="{Binding CommentsText}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.FileSize}}"
                                               FontSize="11"
                                               Foreground="{StaticResource MidGrayBrush}" />
                                    <TextBlock Text="{Binding FileSizeText}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Spacing="6">
                            <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.Tags}}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{Binding TagsText}"
                                       FontSize="13"
                                       Foreground="{StaticResource InkBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="6"
                                    IsVisible="{Binding HasDependencies}">
                            <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.Dependencies}}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MidGrayBrush}" />
                            <ItemsControl ItemsSource="{Binding Dependencies}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="api:RemoteModDependency">
                                        <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                BorderBrush="{StaticResource HairlineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,6"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <LucideIcon Kind="Link" Size="14" Foreground="{StaticResource MidGrayBrush}" />
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource InkBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock FontSize="12"
                                                           Foreground="{StaticResource MidGrayBrush}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="v" /><Run Text="{Binding Version}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock Text="{c:I18n {x:Static i18n:ModDetail.NoDependencies}}"
                                   FontSize="13"
                                   Foreground="{StaticResource MidGrayBrush}"
                                   FontStyle="Italic"
                                   IsVisible="{Binding !HasDependencies}" />
                    </StackPanel>
                </ScrollViewer>
            </Panel>

            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto,Auto"
                  Margin="0,16,0,0">
                <Border Grid.Column="0"
                        Background="{StaticResource BgSurfaceAltBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasDownloadStatus}">
                    <TextBlock Text="{Binding DownloadStatus}"
                               FontSize="12"
                               Foreground="{StaticResource InkSoftBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Button Grid.Column="1"
                        Classes="primary iconText"
                        Command="{Binding DownloadCommand}"
                        IsEnabled="{Binding CanDownload}"
                        Margin="0,0,8,0"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <LucideIcon Kind="Download"
                                    Size="16"
                                    Foreground="{StaticResource BgPaperBrush}"
                                    IsVisible="{Binding !IsDownloading}" />
                        <LucideIcon Kind="Loader"
                                    Size="16"
                                    Classes="loader"
                                    Foreground="{StaticResource BgPaperBrush}"
                                    IsVisible="{Binding IsDownloading}" />
                        <TextBlock Text="{Binding DownloadButtonText}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding CloseCommand}"
                        Padding="20,10"
                        Content="{c:I18n {x:Static i18n:Common.Close}}" />
            </Grid>
        </Grid>
    </Border>
</Window>