<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnturnedModLoader.ViewModels"
        xmlns:i18n="using:UnturnedModLoader.I18n"
        xmlns:c="https://codewf.com"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="680" d:DesignHeight="520"
        x:Class="UnturnedModLoader.Views.SettingsWindow"
        x:Name="settingsRoot"
        x:DataType="vm:SettingsViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{c:I18n {x:Static i18n:Settings.Title}}"
        Width="680" Height="520"
        MinWidth="600" MinHeight="480"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgCanvasBrush}">

    <Border Margin="20"
            Background="{StaticResource BgPaperBrush}"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24,20">
        <Grid RowDefinitions="Auto,*,Auto">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="32" Height="32"
                            CornerRadius="8"
                            Background="{StaticResource InkBrush}">
                        <LucideIcon Kind="Settings"
                                    Size="18"
                                    Foreground="{StaticResource BgPaperBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{c:I18n {x:Static i18n:Settings.Title}}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="icon"
                        HorizontalAlignment="Right"
                        Command="{Binding CloseCommand}"
                        ToolTip.Tip="{c:I18n {x:Static i18n:Common.Close}}">
                    <LucideIcon Kind="X" Size="18" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="148,*">

                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                    <Button Classes="sidebar"
                            Classes.selected="{Binding IsGameSection}"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="game">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="Folder" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Settings.GameSection}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar"
                            Classes.selected="{Binding IsProfilesSection}"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="profiles">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="Layers" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Settings.ProfilesSection}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar"
                            Classes.selected="{Binding IsAccountSection}"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="account">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="UserRound" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Settings.AccountSection}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar"
                            Classes.selected="{Binding IsAppearanceSection}"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="appearance">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="SunMoon" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Settings.AppearanceSection}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource BgSurfaceAltBrush}"
                        BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20,18">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <Panel>

                        <StackPanel IsVisible="{Binding IsGameSection}" Spacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{c:I18n {x:Static i18n:Settings.GameInstallTitle}}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{c:I18n {x:Static i18n:Settings.GameInstallDesc}}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="18" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="{c:I18n {x:Static i18n:Common.Path}}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MidGrayBrush}" />
                                <TextBox Text="{Binding GamePath}"
                                         PlaceholderText="{c:I18n {x:Static i18n:Onboarding.GamePathPlaceholder}}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="iconText"
                                        Command="{Binding AutoDetectGamePathCommand}"
                                        IsEnabled="{Binding !IsDetecting}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="ScanSearch" Size="16" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:Common.AutoDetect}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="iconText"
                                        Command="{Binding BrowseGamePathCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="FolderOpen" Size="16" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:Common.Browse}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Border Background="{StaticResource BgPaperBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <TextBlock Text="{Binding GamePathStatus}"
                                           FontSize="12"
                                           Foreground="{StaticResource InkSoftBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,4,0,0" />

                            <StackPanel Spacing="6">
                                <TextBlock Text="{c:I18n {x:Static i18n:WinFspKeys.Title}}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{c:I18n {x:Static i18n:WinFspKeys.Desc}}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="18" />
                            </StackPanel>

                            <Border Background="{StaticResource BgPaperBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <TextBlock Text="{Binding WinFspStatusText}"
                                           FontSize="12"
                                           Foreground="{StaticResource InkSoftBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="primary iconText"
                                        Command="{Binding InstallWinFspCommand}"
                                        IsVisible="{Binding CanInstallWinFsp}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="Download" Size="16" Foreground="{StaticResource BgPaperBrush}" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:WinFspKeys.Install}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="iconText"
                                        Command="{Binding RefreshWinFspStatusCommand}"
                                        IsEnabled="{Binding !IsWinFspChecking}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="RefreshCw" Size="16" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:WinFspKeys.Recheck}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <TextBlock Text="{Binding WinFspActionStatus}"
                                       FontSize="12"
                                       Foreground="{StaticResource MidGrayBrush}"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding WinFspActionStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsProfilesSection}" Spacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{c:I18n {x:Static i18n:ProfileKeys.Title}}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{c:I18n {x:Static i18n:ProfileKeys.Desc}}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="18" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Text="{Binding NewProfileName}"
                                         Width="200"
                                         PlaceholderText="{c:I18n {x:Static i18n:ProfileKeys.NewName}}" />
                                <Button Classes="primary iconText"
                                        Command="{Binding CreateProfileCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="Plus" Size="16" Foreground="{StaticResource BgPaperBrush}" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:ProfileKeys.Create}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Profiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProfileItemViewModel">
                                        <Border Background="{StaticResource BgPaperBrush}"
                                                BorderBrush="{StaticResource HairlineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,10"
                                                Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource InkBrush}" />
                                                        <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                IsVisible="{Binding IsActive}">
                                                            <TextBlock Text="{c:I18n {x:Static i18n:ProfileKeys.Active}}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource MidGrayBrush}" />
                                                        </Border>
                                                        <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                IsVisible="{Binding IsBuiltIn}">
                                                            <TextBlock Text="{c:I18n {x:Static i18n:ProfileKeys.BuiltIn}}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource MidGrayBrush}" />
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <Button Classes="iconText"
                                                            Command="{Binding #settingsRoot.((vm:SettingsViewModel)DataContext).ActivateProfileCommand}"
                                                            CommandParameter="{Binding}"
                                                            IsVisible="{Binding !IsActive}">
                                                        <TextBlock Text="{c:I18n {x:Static i18n:ProfileKeys.SetActive}}" />
                                                    </Button>
                                                    <Button Classes="icon"
                                                            ToolTip.Tip="{c:I18n {x:Static i18n:ProfileKeys.OpenFolder}}"
                                                            Command="{Binding #settingsRoot.((vm:SettingsViewModel)DataContext).OpenProfileFolderCommand}"
                                                            CommandParameter="{Binding}"
                                                            IsVisible="{Binding !IsVanilla}">
                                                        <LucideIcon Kind="FolderOpen" Size="16" />
                                                    </Button>
                                                    <Button Classes="icon"
                                                            ToolTip.Tip="{c:I18n {x:Static i18n:ProfileKeys.Delete}}"
                                                            Command="{Binding #settingsRoot.((vm:SettingsViewModel)DataContext).DeleteProfileCommand}"
                                                            CommandParameter="{Binding}"
                                                            IsVisible="{Binding !IsBuiltIn}">
                                                        <LucideIcon Kind="Trash2" Size="16" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding ProfileStatus}"
                                       FontSize="12"
                                       Foreground="{StaticResource MidGrayBrush}"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding ProfileStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsAccountSection}" Spacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{c:I18n {x:Static i18n:Settings.CurrentAccountTitle}}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{c:I18n {x:Static i18n:Settings.CurrentAccountDesc}}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="18" />
                            </StackPanel>

                            <StackPanel Spacing="12"
                                        IsVisible="{Binding !IsLoggedIn}">
                                <Border Background="{StaticResource BgPaperBrush}"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,10">
                                    <TextBlock Text="{c:I18n {x:Static i18n:Settings.GuestAccountHint}}"
                                               FontSize="12"
                                               Foreground="{StaticResource InkSoftBrush}"
                                               TextWrapping="Wrap" />
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="primary iconText"
                                            Command="{Binding OpenLoginCommand}"
                                            IsEnabled="{Binding !IsAccountLoading}"
                                            Padding="16,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="LogIn" Size="16" Foreground="{StaticResource BgPaperBrush}" />
                                            <TextBlock Text="{c:I18n {x:Static i18n:Settings.Login}}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="iconText"
                                            Command="{Binding OpenRegisterCommand}"
                                            IsEnabled="{Binding !IsAccountLoading}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <LucideIcon Kind="UserPlus" Size="16" />
                                            <TextBlock Text="{c:I18n {x:Static i18n:Settings.Register}}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0"
                                  IsVisible="{Binding IsLoggedIn}">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{c:I18n {x:Static i18n:Common.Username}}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}"
                                           Margin="0,0,16,10" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Username}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}"
                                           Margin="0,0,0,10" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{c:I18n {x:Static i18n:Common.Email}}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}"
                                           Margin="0,0,16,10" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Email}"
                                           FontSize="13"
                                           Foreground="{StaticResource InkBrush}"
                                           Margin="0,0,0,10" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{c:I18n {x:Static i18n:Common.Role}}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}"
                                           Margin="0,0,16,0" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding RoleLabel}"
                                           FontSize="13"
                                           Foreground="{StaticResource InkBrush}" />
                            </Grid>

                            <Border Background="{StaticResource BgPaperBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    IsVisible="{Binding AccountStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding AccountStatus}"
                                           FontSize="12"
                                           Foreground="{StaticResource InkSoftBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        IsVisible="{Binding IsLoggedIn}">
                                <Button Classes="iconText"
                                        Command="{Binding RefreshAccountCommand}"
                                        IsEnabled="{Binding !IsAccountLoading}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="RefreshCw" Size="16" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:Settings.RefreshAccount}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="iconText"
                                        Command="{Binding LogoutCommand}"
                                        IsEnabled="{Binding !IsAccountLoading}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="LogOut" Size="16" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:Settings.Logout}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsAppearanceSection}" Spacing="20">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{c:I18n {x:Static i18n:ThemeKeys.Title}}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="{c:I18n {x:Static i18n:ThemeKeys.Desc}}"
                                               FontSize="12"
                                               Foreground="{StaticResource MidGrayBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="18" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="segment"
                                            Classes.selected="{Binding IsLightThemeSelected}"
                                            Command="{Binding SelectThemeCommand}"
                                            CommandParameter="light"
                                            Padding="14,10">
                                        <TextBlock Text="{c:I18n {x:Static i18n:ThemeKeys.Light}}" />
                                    </Button>
                                    <Button Classes="segment"
                                            Classes.selected="{Binding IsDarkThemeSelected}"
                                            Command="{Binding SelectThemeCommand}"
                                            CommandParameter="dark"
                                            Padding="14,10">
                                        <TextBlock Text="{c:I18n {x:Static i18n:ThemeKeys.Dark}}" />
                                    </Button>
                                    <Button Classes="segment"
                                            Classes.selected="{Binding IsSystemThemeSelected}"
                                            Command="{Binding SelectThemeCommand}"
                                            CommandParameter="system"
                                            Padding="14,10">
                                        <TextBlock Text="{c:I18n {x:Static i18n:ThemeKeys.System}}" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource HairlineBrush}" />

                            <StackPanel Spacing="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{c:I18n {x:Static i18n:LocaleKeys.Title}}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="{c:I18n {x:Static i18n:LocaleKeys.Desc}}"
                                               FontSize="12"
                                               Foreground="{StaticResource MidGrayBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="18" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="segment"
                                            Classes.selected="{Binding IsZhLocaleSelected}"
                                            Command="{Binding SelectLocaleCommand}"
                                            CommandParameter="zh"
                                            Padding="14,10">
                                        <TextBlock Text="{c:I18n {x:Static i18n:LocaleKeys.Zh}}" />
                                    </Button>
                                    <Button Classes="segment"
                                            Classes.selected="{Binding IsEnLocaleSelected}"
                                            Command="{Binding SelectLocaleCommand}"
                                            CommandParameter="en"
                                            Padding="14,10">
                                        <TextBlock Text="{c:I18n {x:Static i18n:LocaleKeys.En}}" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Panel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,16,0,0">
                <Button Content="{c:I18n {x:Static i18n:Common.Close}}"
                        Classes="primary"
                        Command="{Binding CloseCommand}"
                        Padding="20,8" />
            </StackPanel>
        </Grid>
    </Border>
</Window>