<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnturnedModLoader.ViewModels"
        xmlns:controls="using:UnturnedModLoader.Controls"
        xmlns:i18n="using:UnturnedModLoader.I18n"
        xmlns:c="https://codewf.com"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1024" d:DesignHeight="680"
        x:Class="UnturnedModLoader.Views.MainWindow"
        x:Name="MainView"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{c:I18n {x:Static i18n:Common.AppName}}"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="520"
        Background="{StaticResource BgCanvasBrush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0"
                Background="{StaticResource BgPaperBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="36" Height="36"
                            CornerRadius="8"
                            Background="{StaticResource InkBrush}">
                        <LucideIcon Kind="Gamepad2"
                                    Size="20"
                                    Foreground="{StaticResource BgPaperBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{c:I18n {x:Static i18n:Common.AppName}}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="{c:I18n {x:Static i18n:Main.Subtitle}}"
                                   FontSize="12"
                                   Foreground="{StaticResource MidGrayBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0"
                                IsVisible="{Binding Username, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <LucideIcon Kind="UserRound" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                        <TextBlock Text="{Binding Username}"
                                   FontSize="13"
                                   Foreground="{StaticResource InkBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Classes="icon"
                            ToolTip.Tip="{c:I18n {x:Static i18n:Common.Settings}}"
                            Command="{Binding OpenSettingsCommand}">
                        <LucideIcon Kind="Settings" Size="18" />
                    </Button>
                    <Button Classes="primary iconText" Padding="14,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <LucideIcon Kind="Play" Size="16" Foreground="{StaticResource BgPaperBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Main.LaunchGame}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="200,*">

            <Border Grid.Column="0"
                    Background="{StaticResource BgPaperBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12,16">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,8">
                        <LucideIcon Kind="LayoutGrid" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                        <TextBlock Text="{c:I18n {x:Static i18n:Main.Navigation}}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MidGrayBrush}"
                                   LetterSpacing="0.5"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Classes="sidebar"
                            Classes.selected="{Binding IsBrowsePage}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="browse">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="Cloud" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Main.BrowseMods}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar"
                            Classes.selected="{Binding IsInstalledPage}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="installed">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="HardDrive" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Main.InstalledMods}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel Spacing="4" IsVisible="{Binding IsBrowsePage}">
                        <Border Height="1"
                                Background="{StaticResource HairlineBrush}"
                                Margin="4,12" />

                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,8">
                            <LucideIcon Kind="Tags" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{c:I18n {x:Static i18n:Main.Categories}}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MidGrayBrush}"
                                       LetterSpacing="0.5"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryViewModel">
                                    <Button Classes="sidebar"
                                            Classes.selected="{Binding IsSelected}"
                                            Command="{Binding #MainView.((vm:MainViewModel)DataContext).SelectCategoryCommand}"
                                            CommandParameter="{Binding Key}">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <LucideIcon Kind="{Binding IconKind}"
                                                        Size="16"
                                                        Foreground="{StaticResource MidGrayBrush}" />
                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="20">

                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                    <Border Grid.Column="0"
                            Background="{StaticResource BgPaperBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid ColumnDefinitions="Auto,*">
                            <LucideIcon Grid.Column="0"
                                        Kind="Search"
                                        Size="16"
                                        Foreground="{StaticResource MidGrayBrush}"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Classes="search"
                                     PlaceholderText="{c:I18n {x:Static i18n:Main.SearchPlaceholder}}"
                                     Text="{Binding SearchText}"
                                     Background="Transparent"
                                     BorderThickness="0" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="12,0,0,0">
                        <Button Classes="icon"
                                ToolTip.Tip="{c:I18n {x:Static i18n:Main.AddMod}}"
                                IsVisible="{Binding IsBrowsePage}">
                            <LucideIcon Kind="Plus" Size="18" />
                        </Button>
                        <Button Classes="icon"
                                ToolTip.Tip="{c:I18n {x:Static i18n:Common.Refresh}}"
                                Command="{Binding RefreshModsCommand}"
                                IsEnabled="{Binding !IsLoading}">
                            <LucideIcon Kind="RefreshCw" Size="18" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Panel Grid.Row="1">

                    <Border IsVisible="{Binding IsLoading}"
                            Background="{StaticResource LoadingOverlayBrush}"
                            CornerRadius="12"
                            ZIndex="2">
                        <StackPanel Spacing="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <LucideIcon Kind="Loader"
                                        Size="28"
                                        Classes="loader"
                                        Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{Binding ListMessage}"
                                       FontSize="13"
                                       Foreground="{StaticResource MidGrayBrush}" />
                        </StackPanel>
                    </Border>

                    <Border IsVisible="{Binding IsEmpty}"
                            IsHitTestVisible="True"
                            Background="Transparent"
                            ZIndex="1">
                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="400"
                                Padding="36,32"
                                Background="{StaticResource BgPaperBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <StackPanel Spacing="16" HorizontalAlignment="Center">
                                <Border Width="72" Height="72"
                                        CornerRadius="36"
                                        Background="{StaticResource BgSurfaceAltBrush}"
                                        HorizontalAlignment="Center">
                                    <Panel>
                                        <LucideIcon Kind="PackageOpen"
                                                    Size="32"
                                                    Foreground="{StaticResource MidGrayBrush}"
                                                    IsVisible="{Binding ShowPackageEmptyIcon}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                        <LucideIcon Kind="SearchX"
                                                    Size="32"
                                                    Foreground="{StaticResource MidGrayBrush}"
                                                    IsVisible="{Binding ShowSearchEmptyIcon}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                        <LucideIcon Kind="WifiOff"
                                                    Size="32"
                                                    Foreground="{StaticResource EmberBrush}"
                                                    IsVisible="{Binding ShowErrorEmptyIcon}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                    </Panel>
                                </Border>

                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding EmptyStateTitle}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center" />
                                    <TextBlock Text="{Binding EmptyStateSubtitle}"
                                               FontSize="13"
                                               Foreground="{StaticResource MidGrayBrush}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               LineHeight="20"
                                               MaxWidth="320" />
                                </StackPanel>

                                <Button Classes="primary iconText"
                                        Command="{Binding RefreshModsCommand}"
                                        HorizontalAlignment="Center"
                                        Padding="16,10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="RefreshCw" Size="16" Foreground="{StaticResource BgPaperBrush}" />
                                        <TextBlock Text="{c:I18n {x:Static i18n:Main.Reload}}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Border>

                    <ScrollViewer IsVisible="{Binding !IsEmpty}">
                        <Panel>
                            <ItemsControl ItemsSource="{Binding Mods}"
                                          IsVisible="{Binding IsBrowsePage}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModItemViewModel">
                                        <Button Classes="mod-card"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Margin="0,0,0,8"
                                                Command="{Binding #MainView.((vm:MainViewModel)DataContext).OpenModDetailsCommand}"
                                                CommandParameter="{Binding}">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <controls:ModCoverPreview Grid.Column="0"
                                                                          Source="{Binding CoverImage}"
                                                                          HasImage="{Binding HasCoverImage}"
                                                                          PreviewTitle="{Binding Name}"
                                                                          ThumbnailSize="56"
                                                                          HoverZoomSize="220"
                                                                          Margin="0,0,14,0" />

                                                <StackPanel Grid.Column="1" Spacing="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource InkBrush}" />
                                                        <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                                BorderBrush="{StaticResource HairlineBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="6,2">
                                                            <TextBlock Text="{Binding Category}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource MidGrayBrush}" />
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <LucideIcon Kind="UserRound" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                                                        <TextBlock FontSize="12" Foreground="{StaticResource MidGrayBrush}">
                                                            <Run Text="{Binding Author}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding Version}" />
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource InkSoftBrush}"
                                                               TextWrapping="Wrap"
                                                               LineHeight="18"
                                                               MaxHeight="36"
                                                               TextTrimming="CharacterEllipsis"
                                                               Opacity="0.85" />
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding InstalledMods}"
                                          IsVisible="{Binding IsInstalledPage}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InstalledModItemViewModel">
                                        <Border Classes.installed-mod-card="True"
                                                Classes.disabled="{Binding !IsEnabled}"
                                                Background="{StaticResource BgPaperBrush}"
                                                BorderBrush="{StaticResource HairlineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="16,14"
                                                Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                                <ToggleSwitch Grid.Column="0"
                                                              IsChecked="{Binding IsEnabled}"
                                                              IsEnabled="{Binding IsToggleAllowed}"
                                                              ToolTip.Tip="{Binding #MainView.((vm:MainViewModel)DataContext).GameRunningToggleTooltip}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,14,0"
                                                              OnContent=""
                                                              OffContent="" />

                                                <Border Grid.Column="1"
                                                        Width="56" Height="56"
                                                        CornerRadius="8"
                                                        ClipToBounds="True"
                                                        Background="{StaticResource BgSurfaceAltBrush}"
                                                        BorderBrush="{StaticResource HairlineBrush}"
                                                        BorderThickness="1"
                                                        Margin="0,0,14,0">
                                                    <Panel>
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding HasCoverImage}" />
                                                        <LucideIcon Kind="Package"
                                                                    Size="20"
                                                                    Foreground="{StaticResource MidGrayBrush}"
                                                                    IsVisible="{Binding !HasCoverImage}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                    </Panel>
                                                </Border>

                                                <StackPanel Grid.Column="2" Spacing="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource InkBrush}" />
                                                        <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                                BorderBrush="{StaticResource HairlineBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="6,2">
                                                            <TextBlock Text="{Binding Category}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource MidGrayBrush}" />
                                                        </Border>
                                                        <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                                BorderBrush="{StaticResource HairlineBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                IsVisible="{Binding !IsEnabled}">
                                                            <TextBlock Text="{c:I18n {x:Static i18n:InstalledModDetail.DisabledBadge}}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource MidGrayBrush}" />
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <LucideIcon Kind="Tag" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                                                        <TextBlock FontSize="12" Foreground="{StaticResource MidGrayBrush}">
                                                            <Run Text="{Binding Version}" />
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <LucideIcon Kind="File" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                                                        <TextBlock Text="{Binding RelativePath}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource MidGrayBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource InkSoftBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="36"
                                                               TextTrimming="CharacterEllipsis"
                                                               Opacity="0.85"
                                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </StackPanel>

                                                <Button Grid.Column="3"
                                                        Classes="icon"
                                                        ToolTip.Tip="{c:I18n {x:Static i18n:Main.Details}}"
                                                        Padding="8"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0"
                                                        Command="{Binding #MainView.((vm:MainViewModel)DataContext).OpenInstalledModDetailsCommand}"
                                                        CommandParameter="{Binding}">
                                                    <LucideIcon Kind="Info" Size="16" />
                                                </Button>

                                                <Button Grid.Column="4"
                                                        Classes="icon"
                                                        ToolTip.Tip="{c:I18n {x:Static i18n:Main.Remove}}"
                                                        Padding="8"
                                                        VerticalAlignment="Center"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding #MainView.((vm:MainViewModel)DataContext).RemoveInstalledModCommand}"
                                                        CommandParameter="{Binding}">
                                                    <LucideIcon Kind="Trash2" Size="16" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Panel>
                    </ScrollViewer>
                </Panel>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource BgPaperBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <LucideIcon Kind="Folder" Size="14" Foreground="{StaticResource MidGrayBrush}" />
                    <TextBlock Text="{Binding GamePath}"
                               FontSize="12"
                               Foreground="{StaticResource InkBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="500"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                    <LucideIcon Kind="Puzzle" Size="14" Foreground="{StaticResource MidGrayBrush}" />
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource MidGrayBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsInstalledPage}">
                        <Run Text="{Binding EnabledCount}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                        <Run Text="/" />
                        <Run Text="{Binding TotalCount}" />
                    </TextBlock>
                    <TextBlock Text="{Binding TotalCount}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsBrowsePage}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <LucideIcon Kind="CircleCheck" Size="14" Foreground="{StaticResource SuccessBrush}" />
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="{StaticResource MidGrayBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>