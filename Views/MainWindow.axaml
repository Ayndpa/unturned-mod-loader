<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnturnedModLoader.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1024" d:DesignHeight="680"
        x:Class="UnturnedModLoader.Views.MainWindow"
        x:Name="MainView"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Unturned Mod Loader"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="520"
        Background="{StaticResource BgCanvasBrush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPaperBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="36" Height="36"
                            CornerRadius="8"
                            Background="{StaticResource InkBrush}">
                        <LucideIcon Kind="Gamepad2"
                                    Size="20"
                                    Foreground="{StaticResource BgPaperBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Unturned Mod Loader"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="模组加载与管理"
                                   FontSize="12"
                                   Foreground="{StaticResource MidGrayBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Classes="icon" ToolTip.Tip="设置">
                        <LucideIcon Kind="Settings" Size="18" />
                    </Button>
                    <Button Classes="primary iconText" Padding="14,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <LucideIcon Kind="Play" Size="16" Foreground="{StaticResource BgPaperBrush}" />
                            <TextBlock Text="启动游戏" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" ColumnDefinitions="200,*">

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPaperBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12,16">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,8">
                        <LucideIcon Kind="Tags" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                        <TextBlock Text="分类"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MidGrayBrush}"
                                   LetterSpacing="0.5"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CategoryViewModel">
                                <Button Classes="sidebar"
                                        Classes.selected="{Binding IsSelected}"
                                        Command="{Binding #MainView.((vm:MainViewModel)DataContext).SelectCategoryCommand}"
                                        CommandParameter="{Binding Name}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <LucideIcon Kind="{Binding IconKind}"
                                                    Size="16"
                                                    Foreground="{StaticResource MidGrayBrush}" />
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Height="1"
                            Background="{StaticResource HairlineBrush}"
                            Margin="4,16" />

                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,8">
                        <LucideIcon Kind="Zap" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                        <TextBlock Text="快捷操作"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MidGrayBrush}"
                                   LetterSpacing="0.5"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Classes="sidebar">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="FolderOpen" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="打开模组目录" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="sidebar" Command="{Binding BrowseGamePathCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="FolderSearch" Size="16" Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="浏览游戏目录" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Main content -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="20">

                <!-- Toolbar -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                    <Border Grid.Column="0"
                            Background="{StaticResource BgPaperBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid ColumnDefinitions="Auto,*">
                            <LucideIcon Grid.Column="0"
                                        Kind="Search"
                                        Size="16"
                                        Foreground="{StaticResource MidGrayBrush}"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Classes="search"
                                     PlaceholderText="搜索模组..."
                                     Text="{Binding SearchText}"
                                     Background="Transparent"
                                     BorderThickness="0" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="12,0,0,0">
                        <Button Classes="icon" ToolTip.Tip="添加模组">
                            <LucideIcon Kind="Plus" Size="18" />
                        </Button>
                        <Button Classes="icon"
                                ToolTip.Tip="刷新"
                                Command="{Binding RefreshModsCommand}"
                                IsEnabled="{Binding !IsLoading}">
                            <LucideIcon Kind="RefreshCw" Size="18" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Mod list -->
                <Panel Grid.Row="1">

                    <!-- Loading -->
                    <Border IsVisible="{Binding IsLoading}"
                            Background="#99F5F5F5"
                            CornerRadius="12"
                            ZIndex="2">
                        <StackPanel Spacing="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <LucideIcon Kind="Loader"
                                        Size="28"
                                        Classes="loader"
                                        Foreground="{StaticResource MidGrayBrush}" />
                            <TextBlock Text="{Binding ListMessage}"
                                       FontSize="13"
                                       Foreground="{StaticResource MidGrayBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Empty state -->
                    <Border IsVisible="{Binding IsEmpty}"
                            IsHitTestVisible="True"
                            Background="Transparent"
                            ZIndex="1">
                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="400"
                                Padding="36,32"
                                Background="{StaticResource BgPaperBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <StackPanel Spacing="16" HorizontalAlignment="Center">
                                <Border Width="72" Height="72"
                                        CornerRadius="36"
                                        Background="{StaticResource BgSurfaceAltBrush}"
                                        HorizontalAlignment="Center">
                                    <Panel>
                                        <LucideIcon Kind="PackageOpen"
                                                    Size="32"
                                                    Foreground="{StaticResource MidGrayBrush}"
                                                    IsVisible="{Binding ShowPackageEmptyIcon}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                        <LucideIcon Kind="SearchX"
                                                    Size="32"
                                                    Foreground="{StaticResource MidGrayBrush}"
                                                    IsVisible="{Binding ShowSearchEmptyIcon}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                        <LucideIcon Kind="WifiOff"
                                                    Size="32"
                                                    Foreground="{StaticResource EmberBrush}"
                                                    IsVisible="{Binding ShowErrorEmptyIcon}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                    </Panel>
                                </Border>

                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding EmptyStateTitle}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center" />
                                    <TextBlock Text="{Binding EmptyStateSubtitle}"
                                               FontSize="13"
                                               Foreground="{StaticResource MidGrayBrush}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               LineHeight="20"
                                               MaxWidth="320" />
                                </StackPanel>

                                <Button Classes="primary iconText"
                                        Command="{Binding RefreshModsCommand}"
                                        HorizontalAlignment="Center"
                                        Padding="16,10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="RefreshCw" Size="16" Foreground="{StaticResource BgPaperBrush}" />
                                        <TextBlock Text="重新加载" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Border>

                    <ScrollViewer IsVisible="{Binding !IsEmpty}">
                        <ItemsControl ItemsSource="{Binding Mods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModItemViewModel">
                                    <Border Background="{StaticResource BgPaperBrush}"
                                            BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="16,14"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsEnabled}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,14,0" />

                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}" />
                                                    <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                            BorderBrush="{StaticResource HairlineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="6,2">
                                                        <TextBlock Text="{Binding Category}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource MidGrayBrush}" />
                                                    </Border>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <LucideIcon Kind="UserRound" Size="12" Foreground="{StaticResource MidGrayBrush}" />
                                                    <TextBlock FontSize="12" Foreground="{StaticResource MidGrayBrush}">
                                                        <Run Text="{Binding Author}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding Version}" />
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource InkSoftBrush}"
                                                           TextWrapping="Wrap"
                                                           LineHeight="18"
                                                           Opacity="0.85" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <Button Classes="icon" ToolTip.Tip="详情" Padding="8">
                                                    <LucideIcon Kind="Info" Size="16" />
                                                </Button>
                                                <Button Classes="icon" ToolTip.Tip="移除" Padding="8">
                                                    <LucideIcon Kind="Trash2" Size="16" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Panel>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPaperBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <LucideIcon Kind="Folder" Size="14" Foreground="{StaticResource MidGrayBrush}" />
                    <TextBlock Text="{Binding GamePath}"
                               FontSize="12"
                               Foreground="{StaticResource InkBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="500"
                               VerticalAlignment="Center" />
                    <Button Classes="icon"
                            ToolTip.Tip="浏览游戏目录"
                            Command="{Binding BrowseGamePathCommand}"
                            Padding="6">
                        <LucideIcon Kind="FolderOpen" Size="14" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                    <LucideIcon Kind="Puzzle" Size="14" Foreground="{StaticResource MidGrayBrush}" />
                    <TextBlock FontSize="12" Foreground="{StaticResource MidGrayBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding EnabledCount}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                        <Run Text="/" />
                        <Run Text="{Binding TotalCount}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <LucideIcon Kind="CircleCheck" Size="14" Foreground="{StaticResource SuccessBrush}" />
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="{StaticResource MidGrayBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>