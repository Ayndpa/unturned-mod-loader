<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnturnedModLoader.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1024" d:DesignHeight="680"
        x:Class="UnturnedModLoader.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Unturned Mod Loader"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="520"
        Background="{StaticResource BgCanvasBrush}">



    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPaperBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="36" Height="36"
                            CornerRadius="8"
                            Background="{StaticResource InkBrush}">
                        <TextBlock Text="U"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BgPaperBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Unturned Mod Loader"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Text="模组加载与管理"
                                   FontSize="12"
                                   Foreground="{StaticResource MidGrayBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Content="设置" />
                    <Button Classes="primary" Content="启动游戏" Padding="16,8" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" ColumnDefinitions="200,*">

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgPaperBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12,16">
                <StackPanel Spacing="4">
                    <TextBlock Text="分类"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MidGrayBrush}"
                               Margin="12,0,0,8"
                               LetterSpacing="0.5" />

                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CategoryViewModel">
                                <Button Classes="sidebar"
                                        Content="{Binding Label}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Height="1"
                            Background="{StaticResource HairlineBrush}"
                            Margin="4,16" />

                    <TextBlock Text="快捷操作"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MidGrayBrush}"
                               Margin="12,0,0,8"
                               LetterSpacing="0.5" />

                    <Button Classes="sidebar" Content="打开模组目录" />
                    <Button Classes="sidebar" Content="浏览游戏目录" />
                </StackPanel>
            </Border>

            <!-- Main content -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="20">

                <!-- Toolbar -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                    <TextBox Grid.Column="0"
                             PlaceholderText="搜索模组..."
                             Text="{Binding SearchText}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="12,0,0,0">
                        <Button Content="添加模组" />
                        <Button Content="刷新" />
                    </StackPanel>
                </Grid>

                <!-- Mod list -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Mods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ModItemViewModel">
                                <Border Background="{StaticResource BgPaperBrush}"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="16,14"
                                        Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,14,0" />

                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource InkBrush}" />
                                                <Border Background="{StaticResource BgSurfaceAltBrush}"
                                                        BorderBrush="{StaticResource HairlineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <TextBlock Text="{Binding Category}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource MidGrayBrush}" />
                                                </Border>
                                            </StackPanel>

                                            <TextBlock FontSize="12"
                                                       Foreground="{StaticResource MidGrayBrush}">
                                                <Run Text="作者: " />
                                                <Run Text="{Binding Author}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding Version}" />
                                            </TextBlock>

                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkSoftBrush}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="18"
                                                       Opacity="0.85" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                            <Button Content="详情" Padding="10,6" FontSize="12" />
                                            <Button Content="移除" Padding="10,6" FontSize="12" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPaperBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="游戏路径:"
                               FontSize="12"
                               Foreground="{StaticResource MidGrayBrush}" />
                    <TextBlock Text="{Binding GamePath}"
                               FontSize="12"
                               Foreground="{StaticResource InkBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="500" />
                    <Button Content="浏览..."
                            Command="{Binding BrowseGamePathCommand}"
                            Padding="8,4"
                            FontSize="11" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           FontSize="12"
                           Foreground="{StaticResource MidGrayBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0">
                    <Run Text="已启用 " />
                    <Run Text="{Binding EnabledCount}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalCount}" />
                    <Run Text=" 个模组" />
                </TextBlock>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" />
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="{StaticResource MidGrayBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>