<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnturnedModLoader.ViewModels"
        xmlns:i18n="using:UnturnedModLoader.I18n"
        xmlns:c="https://codewf.com"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="640" d:DesignHeight="560"
        x:Class="UnturnedModLoader.Views.InstalledModDetailWindow"
        x:DataType="vm:InstalledModDetailViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{c:I18n {x:Static i18n:InstalledModDetail.Title}}"
        Width="640" Height="560"
        MinWidth="520" MinHeight="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgCanvasBrush}">

    <Border Margin="20"
            Background="{StaticResource BgPaperBrush}"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24,20">
        <Grid RowDefinitions="Auto,*,Auto">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBlock Text="{c:I18n {x:Static i18n:InstalledModDetail.Title}}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Classes="icon"
                        Command="{Binding CloseCommand}"
                        ToolTip.Tip="{c:I18n {x:Static i18n:Common.Close}}">
                    <LucideIcon Kind="X" Size="18" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="16">

                    <Grid ColumnDefinitions="140,*" ColumnSpacing="16">
                        <Border Grid.Column="0"
                                Width="140" Height="140"
                                CornerRadius="10"
                                ClipToBounds="True"
                                Background="{StaticResource BgSurfaceAltBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1">
                            <Panel>
                                <Image Source="{Binding CoverImage}"
                                       Stretch="UniformToFill"
                                       IsVisible="{Binding HasCoverImage}" />
                                <LucideIcon Kind="Package"
                                            Size="32"
                                            Foreground="{StaticResource MidGrayBrush}"
                                            IsVisible="{Binding !HasCoverImage}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                            </Panel>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}"
                                       TextWrapping="Wrap" />
                            <Border Background="{StaticResource BgSurfaceAltBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,3">
                                <TextBlock Text="{Binding Category}"
                                           FontSize="12"
                                           Foreground="{StaticResource MidGrayBrush}" />
                            </Border>
                            <TextBlock FontSize="13" Foreground="{StaticResource MidGrayBrush}">
                                <Run Text="{c:I18n {x:Static i18n:InstalledModDetail.Version}}" />
                                <Run Text=": " />
                                <Run Text="{Binding Version}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding Description}"
                               FontSize="13"
                               Foreground="{StaticResource InkSoftBrush}"
                               TextWrapping="Wrap"
                               LineHeight="20" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="{c:I18n {x:Static i18n:InstalledModDetail.FileCount}}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MidGrayBrush}" />
                        <TextBlock Text="{Binding FileCount}"
                                   FontSize="13"
                                   Foreground="{StaticResource InkBrush}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Classes="primary"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0"
                    Padding="20,10"
                    Content="{c:I18n {x:Static i18n:Common.Close}}" />
        </Grid>
    </Border>
</Window>
