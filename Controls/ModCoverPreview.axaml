<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UnturnedModLoader.Controls.ModCoverPreview"
             x:Name="Root">

    <Grid>
        <Border x:Name="CoverHost"
                Width="{Binding ThumbnailSize, ElementName=Root}"
                Height="{Binding ThumbnailSize, ElementName=Root}"
                CornerRadius="8"
                ClipToBounds="True"
                Background="{StaticResource BgSurfaceAltBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                BorderThickness="1"
                Classes.cover-preview-host=""
                PointerEntered="OnCoverPointerEntered"
                PointerExited="OnCoverPointerExited"
                PointerPressed="OnCoverPointerPressed">
            <Panel>
                <Image x:Name="CoverImage"
                       Source="{Binding Source, ElementName=Root}"
                       Stretch="UniformToFill"
                       RenderTransformOrigin="0.5,0.5"
                       IsVisible="{Binding HasImage, ElementName=Root}">
                    <Image.Transitions>
                        <Transitions>
                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                        </Transitions>
                    </Image.Transitions>
                </Image>
                <LucideIcon Kind="ImageOff"
                            Size="{Binding PlaceholderIconSize, ElementName=Root}"
                            Foreground="{StaticResource MidGrayBrush}"
                            IsVisible="{Binding !HasImage, ElementName=Root}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
            </Panel>
        </Border>

        <Popup x:Name="HoverPopup"
               PlacementTarget="{Binding #CoverHost}"
               Placement="Right"
               HorizontalOffset="12"
               IsLightDismissEnabled="False"
               WindowManagerAddShadowHint="True">
            <Border x:Name="HoverPopupHost"
                    Background="{StaticResource BgPaperBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="4"
                    BoxShadow="0 8 24 0 #33000000"
                    PointerEntered="OnHoverPopupPointerEntered"
                    PointerExited="OnHoverPopupPointerExited">
                <Border Width="{Binding HoverZoomSize, ElementName=Root}"
                        Height="{Binding HoverZoomSize, ElementName=Root}"
                        CornerRadius="8"
                        ClipToBounds="True"
                        Background="{StaticResource BgSurfaceAltBrush}">
                    <Image Source="{Binding Source, ElementName=Root}"
                           Stretch="Uniform" />
                </Border>
            </Border>
        </Popup>
    </Grid>
</UserControl>